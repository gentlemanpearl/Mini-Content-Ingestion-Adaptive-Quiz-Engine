
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/sourceDocuments/{sourceDocumentId} {
      allow get, list, create, update, delete: if isOwner(userId);
      match /contentChunks/{chunkId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    match /quizQuestions/{questionId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /students/{studentId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(studentId);
      match /studentAnswers/{answerId} {
        allow get, list: if isSignedIn();
        allow create, update: if isOwner(studentId);
      }
    }

    match /{path=**}/studentAnswers/{answerId} {
      allow list: if isSignedIn();
    }
  }
}
