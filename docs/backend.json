{
  "entities": {
    "SourceDocument": {
      "title": "SourceDocument",
      "description": "Represents an uploaded PDF file from which educational content is extracted and processed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "filename": { "type": "string" },
        "uploadDate": { "type": "string", "format": "date-time" },
        "fileSizeKB": { "type": "number" },
        "mimeType": { "type": "string" },
        "status": { "type": "string", "enum": ["uploaded", "processing", "processed", "failed"] }
      },
      "required": ["id", "filename", "uploadDate", "fileSizeKB", "mimeType", "status"]
    },
    "ContentChunk": {
      "title": "ContentChunk",
      "description": "Represents a segment of text extracted from a SourceDocument.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sourceDocumentId": { "type": "string" },
        "chunkIndex": { "type": "number" },
        "grade": { "type": "number" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "text": { "type": "string" },
        "extractionDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sourceDocumentId", "chunkIndex", "grade", "subject", "topic", "text", "extractionDate"]
    },
    "QuizQuestion": {
      "title": "QuizQuestion",
      "description": "Represents a generated quiz question.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sourceChunkId": { "type": "string" },
        "questionText": { "type": "string" },
        "questionType": { "type": "string", "enum": ["MCQ", "True/False", "Fill in the blank"] },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "generatedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sourceChunkId", "questionText", "questionType", "correctAnswer", "difficulty", "generatedDate"]
    },
    "Student": {
      "title": "Student",
      "description": "Represents a student and their cognitive profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "currentSkillLevel": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "currentSkillLevel"]
    },
    "StudentAnswer": {
      "title": "StudentAnswer",
      "description": "Records a student's answer to a quiz question.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "quizQuestionId": { "type": "string" },
        "submittedAnswer": { "type": "string" },
        "isCorrect": { "type": "boolean" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "difficultyAtTimeOfAnswer": { "type": "string" }
      },
      "required": ["id", "studentId", "quizQuestionId", "submittedAnswer", "isCorrect", "submittedAt", "difficultyAtTimeOfAnswer"]
    }
  },
  "auth": {
    "providers": ["google.com", "anonymous"]
  },
  "firestore": {
    "/users/{userId}/sourceDocuments/{sourceDocumentId}": {
      "schema": { "$ref": "#/entities/SourceDocument" },
      "description": "Admin document repository."
    },
    "/users/{userId}/sourceDocuments/{sourceDocumentId}/contentChunks/{contentChunkId}": {
      "schema": { "$ref": "#/entities/ContentChunk" },
      "description": "Extracted text segments."
    },
    "/quizQuestions/{quizQuestionId}": {
      "schema": { "$ref": "#/entities/QuizQuestion" },
      "description": "Global question pool."
    },
    "/students/{studentId}": {
      "schema": { "$ref": "#/entities/Student" },
      "description": "Student cognitive profiles."
    },
    "/students/{studentId}/studentAnswers/{answerId}": {
      "schema": { "$ref": "#/entities/StudentAnswer" },
      "description": "Individual student answer history."
    }
  }
}